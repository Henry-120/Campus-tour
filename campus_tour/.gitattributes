# Flutter 專案常用設定

# 預設所有文字檔案使用 LF
* text=auto eol=lf

# Dart 檔案強制 LF
*.dart text eol=lf

# JSON 檔案強制 LF
*.json text eol=lf

# YAML 檔案強制 LF
*.yaml text eol=lf
*.yml text eol=lf

# Markdown 檔案強制 LF
*.md text eol=lf

# HTML / CSS / JS 檔案強制 LF
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# 二進位檔案不要轉換
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.mp4 binary
*.mp3 binary
